// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  
  // App-specific relations
  preferences   UserPreferences?
  conversations Conversation[]
  feedback      Feedback[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models
model UserPreferences {
  id               String @id @default(cuid())
  userId           String @unique
  languageRegion   String @default("en-US")
  languageName     String @default("English")
  topic            String @default("Casual Conversation")
  voice            String @default("Aoede")
  proficiencyLevel String @default("Intermediate")
  conversationType String @default("Language Practice")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?  // Auto-generated from topic or first message
  language  String?  // The language spoken (e.g. Hindi)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" or "model"
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum FeedbackType {
  FEEDBACK
  ISSUE
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String?
  type      FeedbackType   @default(FEEDBACK)
  message   String         @db.Text
  status    FeedbackStatus @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}
